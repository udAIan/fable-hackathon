# ---------------------------------------------------------------------------
# apps/server  (Railway)
# ---------------------------------------------------------------------------
# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# E2B (sandbox provider) — also used by the template build script
E2B_API_KEY=

# Anthropic API key — used by Claude Code running INSIDE the sandbox
ANTHROPIC_API_KEY=

# Claude model alias the in-sandbox agent runs with (opus | sonnet | haiku | full id)
STUDIO_AGENT_MODEL=opus

# Allowed browser origin for CORS (your Cloudflare Pages URL in prod)
WEB_ORIGIN=http://localhost:5173

# Railway injects PORT automatically; defaults to 3001 locally
PORT=3001

# ---------------------------------------------------------------------------
# apps/web  (Cloudflare Pages)
# ---------------------------------------------------------------------------
# Origin of the deployed server (Railway URL in prod)
VITE_API_URL=http://localhost:3001
