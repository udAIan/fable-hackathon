# Neon Postgres connection string (include ?sslmode=require)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# E2B — sandbox provider (also used by the template build script)
E2B_API_KEY=

# Anthropic API key — used by Claude Code running INSIDE the sandbox
ANTHROPIC_API_KEY=

# Deepgram API key — passed into the sandbox for speaker diarization
DEEPGRAM_API_KEY=

# Claude model alias the in-sandbox agent runs with (opus | sonnet | haiku | full id)
STUDIO_AGENT_MODEL=opus

# Allowed browser origin for CORS (the web dev server, or your Pages URL in prod).
# Comma-separated for multiple; "*" allows any origin.
WEB_ORIGIN=http://localhost:5173

# Local port. Railway injects PORT automatically.
PORT=3001
